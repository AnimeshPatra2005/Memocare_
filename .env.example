# Docker Compose Project Configuration
COMPOSE_PROJECT_NAME=memocare

# Supabase Database Configuration (Use IPv4 Connection Pooler - Port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase Auth Configuration (JWT Secret found in Settings -> API)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-key-here
